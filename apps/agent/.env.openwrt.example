# =====================================================================
# Driver de red — TP-Link Archer AX21 con OpenWrt (US-22)
# Copia estas variables a tu apps/agent/.env para activar el driver real.
# Guía completa: docs/openwrt-ax21-setup.md
# Requiere instalar la dep SSH en el servidor:  cd apps/agent && pnpm add node-ssh
# =====================================================================

DRIVER_KIND=openwrt
DRIVER_HOST=192.168.1.1

# Acceso SSH al router (usuario/clave). Tras instalar OpenWrt, root + la contraseña
# que pusiste con `passwd`. Recomendado: usar OPENWRT_SSH_KEY_PATH en vez de password.
OPENWRT_SSH_PORT=22
OPENWRT_SSH_USER=root
OPENWRT_SSH_PASSWORD=tu-contraseña-ssh
# OPENWRT_SSH_KEY_PATH=/home/usuario/.ssh/id_ed25519

# Interfaz WAN (para el muestreo de tráfico) y red de invitados (UCI).
# Verifica los nombres reales con `uci show network` / `uci show wireless` en el router.
# En el AX21 las radios suelen ser radio0 (5GHz) y radio1 (2.4GHz).
OPENWRT_WAN_IFACE=wan
OPENWRT_GUEST_NETWORK=guest
