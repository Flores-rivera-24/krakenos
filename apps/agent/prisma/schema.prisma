// KrakenOS — esquema de datos del agente local (SQLite).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  displayName  String
  passwordHash String
  role         String         @default("viewer") // 'admin' | 'viewer'
  refreshTokens RefreshToken[]
  webAuthnCredentials WebAuthnCredential[]
  backupCodes  BackupCode[]
  /// Desafío WebAuthn temporal (base64url) durante registro/autenticación (US-50).
  webAuthnChallenge    String?
  /// Expiración del desafío WebAuthn (5 min); se invalida al completar.
  webAuthnChallengeExp DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

/// Passkey WebAuthn registrada por un usuario (2FA opcional, US-50).
model WebAuthnCredential {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String   @unique // base64url
  publicKey    Bytes             // clave pública del dispositivo
  counter      Int      @default(0)
  deviceType   String            // 'singleDevice' | 'multiDevice'
  backedUp     Boolean  @default(false)
  name         String            // nombre dado por el usuario: "iPhone", "YubiKey"
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime?

  @@index([userId])
}

/// Código de recuperación 2FA (US-59). Solo se persiste el hash sha256; el texto
/// plano se muestra una sola vez al generarlo. `usedAt` marca el consumo (un solo uso).
model BackupCode {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String // sha256 hex del código
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

/// Ajustes clave/valor del sistema (p. ej. nombre del hogar).
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// Registro de auditoría de acciones relevantes.
model AuditLog {
  id        String   @id @default(cuid())
  action    String          // p. ej. 'auth.login', 'wifi.update', 'device.block'
  userId    String?
  detail    String?         // texto/JSON con contexto adicional
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

/// Refresh tokens persistidos para permitir rotación y revocación.
model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Hash del token (nunca el token en claro).
  tokenHash String   @unique
  revoked   Boolean  @default(false)
  /// Fecha en que el token fue ROTADO (sustituido por uno nuevo en /auth/refresh).
  /// Distingue un token revocado por rotación de uno revocado por logout/admin:
  /// solo el reuso de un token rotado dispara la detección de reuso (US-78, F4).
  rotatedAt DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

/// Rollup periódico (p. ej. 1/min) del uso de ancho de banda para estadísticas
/// históricas. Cada fila es la media de las muestras del intervalo de rollup.
model TrafficSample {
  id            String   @id @default(cuid())
  timestamp     DateTime @default(now())
  /// Media de bytes/seg de descarga (entrada) en el intervalo.
  rxBytesPerSec Float
  /// Media de bytes/seg de subida (salida) en el intervalo.
  txBytesPerSec Float

  @@index([timestamp])
}

/// Suscripción Web Push de un usuario para notificaciones (US-45).
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

/// Rollup periódico (1/min) del uso de ancho de banda por dispositivo (US-46).
/// Cada fila es la media de las muestras del intervalo para una MAC concreta.
model DeviceTrafficSample {
  id            String   @id @default(cuid())
  mac           String
  timestamp     DateTime @default(now())
  /// Media de bytes/seg de descarga (entrada) en el intervalo.
  rxBytesPerSec Float
  /// Media de bytes/seg de subida (salida) en el intervalo.
  txBytesPerSec Float

  @@index([mac, timestamp])
}

model Device {
  id        String   @id @default(cuid())
  mac       String   @unique
  ip        String
  hostname  String?
  label     String?
  vendor    String?
  type      String   @default("unknown")
  notes     String?
  isBlocked Boolean  @default(false)
  online    Boolean  @default(true)
  /// VLAN (tag 802.1Q) asignada, o null si ninguna (US-15).
  vlanTag   Int?
  /// Fuentes de descubrimiento serializadas como JSON: ["arp","mdns"].
  sources   String   @default("[]")
  firstSeen DateTime @default(now())
  lastSeen  DateTime @default(now())

  @@index([online])
}
