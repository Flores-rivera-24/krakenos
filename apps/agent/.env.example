# Copia a `.env` y ajusta. NUNCA subas `.env` ni las claves al repo.

# Servidor
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Base de datos (SQLite local). La ruta es relativa a prisma/schema.prisma,
# así que `file:./dev.db` crea el archivo en apps/agent/prisma/dev.db.
DATABASE_URL="file:./dev.db"

# CORS — origen del frontend en desarrollo
WEB_ORIGIN=http://localhost:5173

# Servido del frontend desde el propio agente (API + UI en un puerto).
# Activo por defecto en producción; en desarrollo (Vite en :5173) ponlo en false.
# SERVE_WEB=false
# WEB_DIST_PATH=../web/dist   # ruta al build de la web (por defecto, relativa a apps/agent)

# JWT RS256 — rutas a las claves PEM (genera con scripts/gen-keys.sh)
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
# Rotación de claves (US-64): claves públicas ANTERIORES que aún deben verificar
# durante el solape (rutas separadas por comas). Solo verifican, nunca firman.
# Se rellena al rotar con scripts/rotate-keys.sh; ver docs/jwt-key-rotation.md.
# JWT_PREVIOUS_PUBLIC_KEY_PATHS=./keys/jwt-public.prev.pem
ACCESS_TOKEN_TTL=900          # 15 min en segundos
REFRESH_TOKEN_TTL=2592000     # 30 días en segundos

# Driver de hardware: mock | openwrt | pfsense | cisco-ios | cisco-netconf | unifi | mikrotik | omada
DRIVER_KIND=mock
DRIVER_HOST=
# OpenWrt real (solo si DRIVER_KIND=openwrt): SSH+UCI contra el router (DRIVER_HOST).
# Requiere el paquete node-ssh en el servidor (pnpm add node-ssh).
OPENWRT_WAN_IFACE=wan
OPENWRT_GUEST_NETWORK=guest
OPENWRT_SSH_PORT=22
OPENWRT_SSH_USER=root
# OPENWRT_SSH_PASSWORD=     # contraseña SSH, o usa OPENWRT_SSH_KEY_PATH
# OPENWRT_SSH_KEY_PATH=     # ruta a la clave privada PEM
# pfSense real (solo si DRIVER_KIND=pfsense): REST API v2 (paquete pfSense API).
# PFSENSE_URL=https://192.168.1.1   # por defecto https://DRIVER_HOST
# PFSENSE_API_KEY=                  # API key del paquete REST API
PFSENSE_WAN_IFACE=wan
PFSENSE_LAN_IFACE=lan
# Cisco IOS real (solo si DRIVER_KIND=cisco-ios): SSH+CLI de IOS contra DRIVER_HOST.
CISCO_USER=admin
# CISCO_PASSWORD=                   # contraseña SSH
CISCO_SSH_PORT=22
# CISCO_ENABLE_PASSWORD=            # contraseña de privilegios (enable), si aplica
CISCO_INTERFACE=GigabitEthernet0/0  # interfaz WAN para métricas de tráfico
CISCO_BLOCK_VLAN=1                   # VLAN para las entradas de bloqueo estáticas
# Cisco IOS-XE 16.6+ vía NETCONF (solo si DRIVER_KIND=cisco-netconf): XML sobre SSH, puerto 830.
# CISCO_NETCONF_HOST=192.168.1.254  # por defecto DRIVER_HOST
CISCO_NETCONF_PORT=830
# CISCO_NETCONF_USER=admin          # por defecto CISCO_USER
# CISCO_NETCONF_PASSWORD=           # por defecto CISCO_PASSWORD
# Driver UniFi Network (solo si DRIVER_KIND=unifi): API local del controller (cuenta local, no SSO).
# UNIFI_URL=https://192.168.1.1     # por defecto https://DRIVER_HOST
# UNIFI_USERNAME=admin
# UNIFI_PASSWORD=changeme
UNIFI_SITE=default
# Driver MikroTik RouterOS (solo si DRIVER_KIND=mikrotik): REST (RouterOS 7) o SSH (CLI).
MIKROTIK_MODE=rest                  # rest | ssh
# MIKROTIK_HOST=192.168.88.1        # por defecto DRIVER_HOST
# MIKROTIK_USER=admin
# MIKROTIK_PASSWORD=
MIKROTIK_WAN_IFACE=ether1           # interfaz WAN para métricas de tráfico
MIKROTIK_HTTPS=true                 # modo rest: usar https (RouterOS www-ssl)
MIKROTIK_SSH_PORT=22                # modo ssh: el paquete node-ssh debe estar instalado
# Driver TP-Link Omada Controller (solo si DRIVER_KIND=omada): API local (controller local, no cloud).
# OMADA_URL=https://192.168.1.10:8043   # por defecto https://DRIVER_HOST
# OMADA_USERNAME=admin
# OMADA_PASSWORD=
OMADA_SITE_NAME=Default             # nombre del site en el controller
# OMADA_OMADAC_ID=                  # vacío → autodetección vía /api/info

# VPN: mock | wireguard. En dev se usa mock (claves reales, sin wg instalado).
VPN_KIND=mock
VPN_ENDPOINT=vpn.krakenos.local
VPN_LISTEN_PORT=51820
# WireGuard real (solo si VPN_KIND=wireguard): se opera vía el helper sudoers.
WG_INTERFACE=wg0
WG_SUBNET=10.8.0.0/24
WG_DNS=10.8.0.1
WG_HELPER_PATH=/usr/local/bin/krakenos-helper
WG_USE_SUDO=true
WG_PEER_STORE=data/wg-peers.json
# WG_SERVER_PUBLIC_KEY=   # opcional; si se omite se consulta a `wg show <iface> public-key`

# IoT: mock | zigbee | matter | hue | govee | tuya. Admite varios a la vez separados por comas
# (p. ej. IOT_KIND=hue,govee → se agregan con CompositeIotManager). En dev se usa mock.
IOT_KIND=mock
# Philips Hue real (solo si IOT_KIND=hue): CLIP API v2 local del bridge.
# HUE_BRIDGE_URL=https://192.168.1.50
# HUE_APP_KEY=                # application key (pulsa el botón del bridge para generarla)
# Govee real (solo si IOT_KIND=govee): API LAN UDP (local). Activa "LAN Control" en la app Govee.
GOVEE_LISTEN_PORT=4002
# Tuya real (solo si IOT_KIND=tuya): focos genéricos de Amazon (EASYTAO…), control local.
# Requiere el paquete tuyapi. La localKey va por dispositivo (API /api/iot/tuya), no aquí.
# Ver docs/tuya-setup.md.
TUYA_CONFIG_PATH=data/tuya-devices.json
# Zigbee real (solo si IOT_KIND=zigbee): zigbee2mqtt vía MQTT. Requiere el paquete mqtt.
ZIGBEE2MQTT_URL=mqtt://localhost:1883
ZIGBEE2MQTT_BASE_TOPIC=zigbee2mqtt
# ZIGBEE2MQTT_USERNAME=
# ZIGBEE2MQTT_PASSWORD=
# Matter real (solo si IOT_KIND=matter): python-matter-server (WebSocket). Requiere el paquete ws.
MATTER_SERVER_URL=ws://localhost:5580/ws

# Cámaras: mock | rtsp. En dev se usa mock (snapshots sintéticos).
CAMERAS_KIND=mock
# RTSP real (solo si CAMERAS_KIND=rtsp): snapshot vía ffmpeg. Requiere el binario ffmpeg.
# CAMERAS_CONFIG: JSON con [{ id, name, room?, model?, rtspUrl, enabled? }] (la rtspUrl no se expone).
CAMERAS_CONFIG=data/cameras.json
FFMPEG_PATH=ffmpeg
CAMERAS_RTSP_TRANSPORT=tcp

# Firewall: mock | iptables. En dev se usa mock (reglas en memoria).
FIREWALL_KIND=mock
# iptables real (solo si FIREWALL_KIND=iptables): se opera vía el helper sudoers.
FW_CHAIN=KRAKENOS
FW_HELPER_PATH=/usr/local/bin/krakenos-helper
FW_USE_SUDO=true
FW_RULE_STORE=data/firewall-rules.json

# VLANs: mock | switch. En dev se usa mock (definiciones en memoria).
VLAN_KIND=mock
# Switch gestionado real (solo si VLAN_KIND=switch): SNMP (Q-BRIDGE-MIB). Requiere net-snmp.
# VLAN_SWITCH_HOST=192.168.1.2
VLAN_SWITCH_COMMUNITY=private
VLAN_SWITCH_SNMP_PORT=161
VLAN_STORE=data/vlans.json
# VLANs en switch Cisco IOS (solo si VLAN_KIND=cisco): SSH+CLI, reusa DRIVER_HOST/CISCO_* (US-38).

# QoS: mock | tc. En dev se usa mock (reglas en memoria).
QOS_KIND=mock
# tc real (solo si QOS_KIND=tc): moldea HTB de una interfaz vía el helper sudoers.
TC_INTERFACE=eth0
TC_LINK_KBIT=1000000
TC_HELPER_PATH=/usr/local/bin/krakenos-helper
TC_USE_SUDO=true
TC_RULE_STORE=data/qos-rules.json

# DNS: mock | pihole. En dev se usa mock (blocklist y stats en memoria).
DNS_KIND=mock
# Pi-hole real (solo si DNS_KIND=pihole): se administra por la API REST (v6).
PIHOLE_URL=http://pi.hole
# PIHOLE_PASSWORD=   # contraseña de la web/app de Pi-hole; vacía si no está configurada

# TLS (opcional). En desarrollo se deja en HTTP. Para servir HTTPS en la LAN:
# genera el cert con ./scripts/gen-cert.sh y pon HTTPS_ENABLED=true.
HTTPS_ENABLED=false
TLS_CERT_PATH=./certs/agent-cert.pem
TLS_KEY_PATH=./certs/agent-key.pem

# Seguridad (cabeceras + proxy).
# TRUST_PROXY=true si el agente corre tras un proxy inverso (nginx), para que
# req.ip (auditoría y rate limit) use X-Forwarded-For.
# TRUST_PROXY=false
# HSTS: por defecto se activa cuando hay HTTPS. Fuérzalo si terminas TLS en el proxy.
# HSTS_ENABLED=true
# Sobreescribe por completo la Content-Security-Policy por defecto (avanzado).
# CONTENT_SECURITY_POLICY="default-src 'self'; ..."

# --- WebAuthn / passkey (2FA opcional, US-50) ---
# Despliegue recomendado en KrakenOS = Escenario A (TLS nativo del agente + hostname
# resuelto por el propio Pi-hole). Requisitos: HTTPS (arriba, HTTPS_ENABLED=true con
# ./scripts/gen-cert.sh) y un HOSTNAME (no IP — los navegadores rechazan passkeys por IP).
# Guía completa: docs/webauthn-setup.md.
#
# RP ID = dominio (sin protocolo ni puerto). Debe coincidir con el hostname del navegador.
# WEBAUTHN_RP_ID=krakenos.local
# Origen completo (protocolo + host + puerto) tal como lo ve el navegador.
# WEBAUTHN_ORIGIN=https://krakenos.local:3001
# Nombre visible del Relying Party (opcional).
# WEBAUTHN_RP_NAME=KrakenOS
