# Copia a `.env` y ajusta. NUNCA subas `.env` ni las claves al repo.

# Servidor
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Base de datos (SQLite local). La ruta es relativa a prisma/schema.prisma,
# así que `file:./dev.db` crea el archivo en apps/agent/prisma/dev.db.
DATABASE_URL="file:./dev.db"

# CORS — origen del frontend en desarrollo
WEB_ORIGIN=http://localhost:5173

# JWT RS256 — rutas a las claves PEM (genera con scripts/gen-keys.sh)
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
ACCESS_TOKEN_TTL=900          # 15 min en segundos
REFRESH_TOKEN_TTL=2592000     # 30 días en segundos

# Driver de hardware: mock | openwrt | pfsense
DRIVER_KIND=mock
DRIVER_HOST=
# OpenWrt real (solo si DRIVER_KIND=openwrt): SSH+UCI contra el router (DRIVER_HOST).
# Requiere el paquete node-ssh en el servidor (pnpm add node-ssh).
OPENWRT_WAN_IFACE=wan
OPENWRT_GUEST_NETWORK=guest
OPENWRT_SSH_PORT=22
OPENWRT_SSH_USER=root
# OPENWRT_SSH_PASSWORD=     # contraseña SSH, o usa OPENWRT_SSH_KEY_PATH
# OPENWRT_SSH_KEY_PATH=     # ruta a la clave privada PEM
# pfSense real (solo si DRIVER_KIND=pfsense): REST API v2 (paquete pfSense API).
# PFSENSE_URL=https://192.168.1.1   # por defecto https://DRIVER_HOST
# PFSENSE_API_KEY=                  # API key del paquete REST API
PFSENSE_WAN_IFACE=wan
PFSENSE_LAN_IFACE=lan

# VPN: mock | wireguard. En dev se usa mock (claves reales, sin wg instalado).
VPN_KIND=mock
VPN_ENDPOINT=vpn.krakenos.local
VPN_LISTEN_PORT=51820
# WireGuard real (solo si VPN_KIND=wireguard): se opera vía el helper sudoers.
WG_INTERFACE=wg0
WG_SUBNET=10.8.0.0/24
WG_DNS=10.8.0.1
WG_HELPER_PATH=/usr/local/bin/krakenos-helper
WG_USE_SUDO=true
WG_PEER_STORE=data/wg-peers.json
# WG_SERVER_PUBLIC_KEY=   # opcional; si se omite se consulta a `wg show <iface> public-key`

# IoT: mock | zigbee | matter. En dev se usa mock (dispositivos en memoria).
IOT_KIND=mock
# Zigbee real (solo si IOT_KIND=zigbee): zigbee2mqtt vía MQTT. Requiere el paquete mqtt.
ZIGBEE2MQTT_URL=mqtt://localhost:1883
ZIGBEE2MQTT_BASE_TOPIC=zigbee2mqtt
# ZIGBEE2MQTT_USERNAME=
# ZIGBEE2MQTT_PASSWORD=

# Cámaras: mock | rtsp. En dev se usa mock (snapshots sintéticos).
CAMERAS_KIND=mock
# RTSP real (solo si CAMERAS_KIND=rtsp): snapshot vía ffmpeg. Requiere el binario ffmpeg.
# CAMERAS_CONFIG: JSON con [{ id, name, room?, model?, rtspUrl, enabled? }] (la rtspUrl no se expone).
CAMERAS_CONFIG=data/cameras.json
FFMPEG_PATH=ffmpeg
CAMERAS_RTSP_TRANSPORT=tcp

# Firewall: mock | iptables. En dev se usa mock (reglas en memoria).
FIREWALL_KIND=mock
# iptables real (solo si FIREWALL_KIND=iptables): se opera vía el helper sudoers.
FW_CHAIN=KRAKENOS
FW_HELPER_PATH=/usr/local/bin/krakenos-helper
FW_USE_SUDO=true
FW_RULE_STORE=data/firewall-rules.json

# VLANs: mock | switch. En dev se usa mock (definiciones en memoria).
VLAN_KIND=mock

# QoS: mock | tc. En dev se usa mock (reglas en memoria).
QOS_KIND=mock
# tc real (solo si QOS_KIND=tc): moldea HTB de una interfaz vía el helper sudoers.
TC_INTERFACE=eth0
TC_LINK_KBIT=1000000
TC_HELPER_PATH=/usr/local/bin/krakenos-helper
TC_USE_SUDO=true
TC_RULE_STORE=data/qos-rules.json

# DNS: mock | pihole. En dev se usa mock (blocklist y stats en memoria).
DNS_KIND=mock
# Pi-hole real (solo si DNS_KIND=pihole): se administra por la API REST (v6).
PIHOLE_URL=http://pi.hole
# PIHOLE_PASSWORD=   # contraseña de la web/app de Pi-hole; vacía si no está configurada

# TLS (opcional). En desarrollo se deja en HTTP. Para servir HTTPS en la LAN:
# genera el cert con ./scripts/gen-cert.sh y pon HTTPS_ENABLED=true.
HTTPS_ENABLED=false
TLS_CERT_PATH=./certs/agent-cert.pem
TLS_KEY_PATH=./certs/agent-key.pem
