# Copia a `.env` y ajusta. NUNCA subas `.env` ni las claves al repo.

# Servidor
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Base de datos (SQLite local). La ruta es relativa a prisma/schema.prisma,
# así que `file:./dev.db` crea el archivo en apps/agent/prisma/dev.db.
DATABASE_URL="file:./dev.db"

# CORS — origen del frontend en desarrollo
WEB_ORIGIN=http://localhost:5173

# JWT RS256 — rutas a las claves PEM (genera con scripts/gen-keys.sh)
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
ACCESS_TOKEN_TTL=900          # 15 min en segundos
REFRESH_TOKEN_TTL=2592000     # 30 días en segundos

# Driver de hardware: mock | openwrt | pfsense
DRIVER_KIND=mock
DRIVER_HOST=

# VPN: mock | wireguard. En dev se usa mock (claves reales, sin wg instalado).
VPN_KIND=mock
VPN_ENDPOINT=vpn.krakenos.local
VPN_LISTEN_PORT=51820

# IoT: mock | zigbee | matter. En dev se usa mock (dispositivos en memoria).
IOT_KIND=mock

# Cámaras: mock | rtsp. En dev se usa mock (snapshots sintéticos).
CAMERAS_KIND=mock

# Firewall: mock | iptables. En dev se usa mock (reglas en memoria).
FIREWALL_KIND=mock

# VLANs: mock | switch. En dev se usa mock (definiciones en memoria).
VLAN_KIND=mock

# QoS: mock | tc. En dev se usa mock (reglas en memoria).
QOS_KIND=mock

# DNS: mock | pihole. En dev se usa mock (blocklist y stats en memoria).
DNS_KIND=mock

# TLS (opcional). En desarrollo se deja en HTTP. Para servir HTTPS en la LAN:
# genera el cert con ./scripts/gen-cert.sh y pon HTTPS_ENABLED=true.
HTTPS_ENABLED=false
TLS_CERT_PATH=./certs/agent-cert.pem
TLS_KEY_PATH=./certs/agent-key.pem
