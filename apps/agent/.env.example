# Copia a `.env` y ajusta. NUNCA subas `.env` ni las claves al repo.

# Servidor
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Base de datos (SQLite local)
DATABASE_URL="file:./prisma/dev.db"

# CORS — origen del frontend en desarrollo
WEB_ORIGIN=http://localhost:5173

# JWT RS256 — rutas a las claves PEM (genera con scripts/gen-keys.sh)
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
ACCESS_TOKEN_TTL=900          # 15 min en segundos
REFRESH_TOKEN_TTL=2592000     # 30 días en segundos

# Driver de hardware: mock | openwrt | pfsense
DRIVER_KIND=mock
DRIVER_HOST=
