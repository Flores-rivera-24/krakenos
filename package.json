{
  "name": "krakenos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "KrakenOS — plataforma de gestión de red doméstica e IoT",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "prod": "bash scripts/prod.sh",
    "dev": "pnpm -r --parallel dev",
    "dev:agent": "pnpm --filter @krakenos/agent dev",
    "dev:web": "pnpm --filter @krakenos/web dev",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "clean": "pnpm -r exec rm -rf dist node_modules .turbo && rm -rf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/node": "^20.14.0",
    "eslint": "^9.9.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0"
  }
}
